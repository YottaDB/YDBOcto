    . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_aim4","id")=3:1,1:0)
    . . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_aimw0","id")=50:1,%ydboctocursor(cursorId,"keys",1,"skiptest_aimw0","id")=99:1,%ydboctocursor(cursorId,"keys",1,"skiptest_aimw0","id")=100:1,1:0)
    . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_m1","region")="east":1,1:0)
    . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_m3","region")="east":1,1:0)
    . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_max0","id")=50:1,%ydboctocursor(cursorId,"keys",1,"skiptest_max0","id")=99:1,%ydboctocursor(cursorId,"keys",1,"skiptest_max0","id")=100:1,1:0)
    . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_max2","id")=50:1,1:0)
    . . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_s1","id")=99:1,%ydboctocursor(cursorId,"keys",1,"skiptest_s1","id")=100:1,%ydboctocursor(cursorId,"keys",1,"skiptest_s1","id")=101:1,1:0)
    . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_s1","id")=99:1,%ydboctocursor(cursorId,"keys",1,"skiptest_s1","id")=100:1,%ydboctocursor(cursorId,"keys",1,"skiptest_s1","id")=101:1,1:0)
    . QUIT:$SELECT(%ydboctocursor(cursorId,"keys",1,"skiptest_s2","id")="A":1,%ydboctocursor(cursorId,"keys",1,"skiptest_s2","id")="B":1,1:0)
